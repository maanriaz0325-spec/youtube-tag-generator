```json
{
  "version": 2,
  "trailingSlash": false,
  "builds": [
    { "src": "server.ts", "use": "@vercel/node" },
    { "src": "package.json", "use": "@vercel/static-build", "config": { "distDir": "dist" } }
  ],
  "routes": [
    { "src": "/api/generate-tags", "dest": "server.ts" },
    { "src": "/api/fetch-youtube", "dest": "server.ts" },
    { "src": "/api/(.*)", "dest": "server.ts" },
    { "src": "/(.*\\.(js|css|ico|png|svg|json))", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
```